{
  "name": "medium-leetcode-explorer",
  "version": "1.0.0",
  "private": true,
  "description": "Static Medium LeetCode explorer with a reusable Playwright validation harness.",
  "scripts": {
    "test:browser": "node browser-tests/scripts/run-browser-tests.js",
    "test:browser:acceptance": "node browser-tests/scripts/run-browser-tests.js --grep @acceptance",
    "test:browser:explore": "node browser-tests/scripts/run-exploratory-session.js --charter explorer-desktop-sweep",
    "test:browser:explore:content": "node browser-tests/scripts/run-exploratory-session.js --charter explorer-content-expansion-sweep",
    "test:browser:explore:hostile": "node browser-tests/scripts/run-exploratory-session.js --charter explorer-full-product-hostile-audit",
    "test:browser:explore:suggestions007": "node browser-tests/scripts/run-exploratory-session.js --charter explorer-suggestions007-audit",
    "test:browser:repl": "node browser-tests/scripts/exploratory-repl.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
